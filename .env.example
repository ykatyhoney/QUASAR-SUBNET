# =============================================================================
# QUASAR-SUBNET Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# Validator API Configuration
# =============================================================================
# API URL for validators and miners to connect to
# For local testing: http://localhost:8000
VALIDATOR_API_URL=https://quasar-validator-api.onrender.com

# Discrepancy detection: auto-flag miners when claimed vs actual TPS diverges.
# Both percentage AND absolute thresholds must be exceeded to trigger flagging.
# Default: 50% difference AND 1000 tok/s absolute difference
DISCREPANCY_PCT_THRESHOLD=50.0
DISCREPANCY_ABS_THRESHOLD=1000.0

# Submission rate limiting: max 1 submission per COOLDOWN seconds per hotkey.
# Set to 0 to disable. Default: 300 (5 minutes)
SUBMISSION_COOLDOWN_SECONDS=300

# Commit-reveal timing
# Blocks until reveal (default: 100, ~20 minutes at 12s/block)
BLOCKS_UNTIL_REVEAL=100
BLOCK_TIME_SECONDS=12

# =============================================================================
# Miner Configuration (REQUIRED for miners)
# =============================================================================
# GitHub Personal Access Token with 'repo' scope
# Get from: https://github.com/settings/tokens
# Permissions needed: repo (Full control of private repositories)
GITHUB_TOKEN=your_github_token_here

# GitHub username (REQUIRED for miners)
GITHUB_USERNAME=your_github_username

# Optional: Custom fork name (defaults to flash-linear-attention)
GITHUB_FORK_NAME=flash-linear-attention

# Target sequence length for optimization (default: 100000)
# Higher values = higher league multipliers (1M = 3.0x multiplier)
TARGET_SEQUENCE_LENGTH=100000

# Number of optimization iterations (default: 100)
AGENT_ITERATIONS=100

# Seconds between optimization attempts (default: 300 = 5 minutes)
OPTIMIZATION_INTERVAL=300

# =============================================================================
# Context Builder Configuration
# =============================================================================
# Enable full repository context injection (default: true)
USE_FULL_CONTEXT=true

# Maximum number of files to include in context (default: 50)
CONTEXT_MAX_FILES=50

# Maximum context size in characters (default: 200000, ~50K tokens)
CONTEXT_MAX_SIZE=200000

# Path to local repository (optional, for BYOC mode or local testing)
# REPO_PATH=./flash-linear-attention

# Path to expert's optimized code file (Bring-Your-Own-Code mode)
# BYOC_FILE_PATH=./expert_optimized_chunk.py

# =============================================================================
# Model Configuration
# =============================================================================
# Miner model name (for code generation)
MINER_MODEL_NAME=Qwen/Qwen3-4B-Instruct-2507

# =============================================================================
# Bittensor Configuration
# =============================================================================
# Subnet NETUID
NETUID=24

# Network: 'finney' for mainnet, 'test' for testnet
SUBTENSOR_NETWORK=finney

# Wallet names
WALLET_MINER_NAME=your_miner_wallet
WALLET_VALIDATOR_NAME=your_validator_wallet

# Wallet hotkey (default: default)
WALLET_HOTKEY=default

# =============================================================================
# Validator Configuration
# =============================================================================
# Polling interval in seconds (default: 300 = 5 minutes)
POLLING_INTERVAL=300

# Batch size for pending submission processing per cycle (default: 10)
VALIDATOR_PENDING_BATCH_SIZE=10

# Logit verification is MANDATORY -- all miners must pass to rank and earn rewards.
# WARNING: Setting this to false will cause ALL submissions to fail verification.
ENABLE_LOGIT_VERIFICATION=true

# Reference model for inference verification
REFERENCE_MODEL=Qwen/Qwen3-4B-Instruct-2507

# Cosine similarity threshold for logit verification (default: 0.99)
COSINE_SIM_THRESHOLD=0.99

# Maximum absolute difference threshold for logit verification (default: 0.1)
MAX_ABS_DIFF_THRESHOLD=0.1

# =============================================================================
# Container / Docker Configuration (Validator-side)
# =============================================================================
#
# SANDBOX IMAGE (REQUIRED for validators)
# The validator runs miner kernel code inside this Docker image for benchmarking.
# You MUST build it locally on your validator machine before running:
#
#   docker build -t quasar-sandbox:latest -f validator/Dockerfile.sandbox .
#
# Without this image, all performance tests will fail with "pull access denied".
# VALIDATOR_SANDBOX_IMAGE=quasar-sandbox:latest

# Docker Hub username for pushing miner inference images.
DOCKER_USERNAME=your_dockerhub_username

# Override the full docker image name (takes priority over DOCKER_USERNAME).
# MINER_DOCKER_IMAGE=your_dockerhub_username/quasar-miner-gpu:latest

# Container startup timeout in seconds (default: 120)
CONTAINER_STARTUP_TIMEOUT=120

# Container image pull timeout in seconds (default: 600)
CONTAINER_PULL_TIMEOUT=600

# Enable GPU passthrough for container verification (default: true)
CONTAINER_GPU_ENABLED=true

# Container memory limit (default: 16g)
CONTAINER_MEMORY_LIMIT=16g

# Container shared memory size (default: 2g)
CONTAINER_SHM_SIZE=2g

# =============================================================================
# Miner Inference Server Configuration (MINER ONLY)
# =============================================================================
# These settings are for the miner's local inference server (used during
# development/testing before Dockerizing). The validator does NOT use these --
# it pulls the miner's Docker image and runs it in a container.
#
# Port for local inference server (default: 8001)
MINER_INFERENCE_PORT=8001

# Model name for inference server
MODEL_NAME=Qwen/Qwen3-4B-Instruct-2507

# Device: 'cuda' for GPU, 'cpu' for CPU
DEVICE=cuda

# =============================================================================
# Monitoring & Logging (Optional)
# =============================================================================
# WandB API key for monitoring (https://wandb.ai/settings)
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=
# =============================================================================
# Server / Development
# =============================================================================
# API server port (default: 8000)
PORT=8000

# API server host (default: 0.0.0.0)
HOST=0.0.0.0

# Enable debug logging (default: false)
DEBUG=false

# =============================================================================
# Quick Setup Guide
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and fill in:
#    FOR MINERS:
#      - GITHUB_TOKEN (required)
#      - GITHUB_USERNAME (required)
#      - DOCKER_USERNAME (required for logit verification)
#      - WALLET_MINER_NAME
#    FOR VALIDATORS:
#      - VALIDATOR_HOTKEYS (required -- your validator SS58 address)
#      - WALLET_VALIDATOR_NAME
#      - DATABASE_URL (PostgreSQL for production)
#    FOR DASHBOARD DEVS:
#      - API_KEYS (get a read key from the admin)
#      - CORS_ALLOWED_ORIGINS (your dashboard URL)
# 3. Set NETUID and SUBTENSOR_NETWORK for your target network
# 4. Start services using START_*.sh scripts or direct Python commands
